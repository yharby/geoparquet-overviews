{
  "name": "geoparquet-overviews-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "description": "Browser inspector that traces the GeoParquet with overviews read path over HTTP range requests.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@deck.gl/core": "9.3.6",
    "@deck.gl/layers": "9.3.6",
    "@deck.gl/mapbox": "9.3.6",
    "hyparquet": "1.26.2",
    "hyparquet-compressors": "^1.1.1",
    "lit": "3.3.3",
    "maplibre-gl": "5.24.0",
    "proj4": "2.20.9"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24"
  }
}
